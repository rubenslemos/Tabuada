{
  "name": "tabuadamobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "server": "nodemon server.js",
    "client": "expo start --web --port 19006",
    "dev": "concurrently -k -n API,APP -c yellow,cyan \"npm:server\" \"npm:client\"",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "expo:doctor": "npx expo-doctor",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "build:android:prod": "npx eas build --platform android --profile production",
    "submit:android:prod": "npx eas submit --platform android --profile production",
    "test": "jest --config jest.backend.config.cjs --runInBand",
    "test:watch": "jest --config jest.backend.config.cjs --watch",
    "test:coverage": "jest --config jest.backend.config.cjs --coverage",
    "test:ui": "jest --config jest.ui.config.cjs --runInBand",
    "lint": "eslint screens routes models middlewares components config utils tests *.js",
    "lint:fix": "eslint screens routes models middlewares components config utils tests *.js --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@expo-google-fonts/dynapuff": "^0.4.3",
    "@expo-google-fonts/expletus-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/stack": "^7.6.13",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo": "~56.0.6",
    "expo-font": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.4",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.2",
    "nodemailer": "8.0.8",
    "nodemailer-express-handlebars": "^6.1.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^56.0.12",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.2.3",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
