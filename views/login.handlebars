<section class="container">
	<div class="login-container">
		<h1>Login</h1>
		<form id="formLogin" class="tabuada largura registrar">
			<p>E-mail</p>
			<input type="email" name="email" id="emailLogin" placeholder="Digite seu e-mail" value="">
			<p>Senha</p>
			<div><input type="password" name="password" id="passwordLogin" placeholder="Digite sua senha" value=""><i class="fa-regular fa-eye"></i></div>
			<a href="/forgot-password" class="senha" id="esqueceu">Esqueceu a senha?</a>
			<button type="button" id="confirmLogin">Entrar</button>
			<small class="alerta">Não tem conta?</small>
			<a href="/register" class="registrar" id="registrar">Registre-se</a>
		</form>
	</div>
</section>
